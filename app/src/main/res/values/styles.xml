<resources>
    <style name="Theme.Tijario.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F766E</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_app</item>
        <item name="windowSplashScreenIconBackgroundColor">#0F766E</item>
        <item name="postSplashScreenTheme">@style/Theme.Tijario</item>
        <item name="android:windowBackground">#0F766E</item>
        <item name="android:statusBarColor">#0F766E</item>
        <item name="android:navigationBarColor">#0F766E</item>
    </style>

    <style name="Theme.Tijario" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#F7FAFC</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">#F7FAFC</item>
        <item name="android:navigationBarColor">#F7FAFC</item>
        <item name="android:fontFamily">sans</item>
    </style>
</resources>
